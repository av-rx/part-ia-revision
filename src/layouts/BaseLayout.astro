---
import '../styles/base.css';
import { PAPERS, PAPER_ORDER, MODULES, MODULE_ORDER } from '../lib/syllabus';

interface Props {
  title: string;
  description?: string;
  currentModule?: string;
  currentPaper?: string;
  pageTitle?: string;
}

const { title, description = 'Cambridge Computer Science Part IA revision', currentModule, currentPaper } = Astro.props;
const fullTitle = title === 'Part IA Revision' ? title : `${title} · Part IA Revision`;
---
<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script is:inline>
      // Apply dark mode early to avoid flash
      try {
        const stored = localStorage.getItem('theme');
        const prefers = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const dark = stored ? stored === 'dark' : prefers;
        if (dark) document.documentElement.classList.add('dark');
      } catch (_) {}
    </script>
  </head>
  <body class="min-h-full">
    <header class="sticky top-0 z-30 backdrop-blur bg-ink-50/80 dark:bg-ink-950/80 border-b border-ink-200 dark:border-ink-800">
      <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 flex items-center gap-3 h-14">
        <a href="/" class="font-bold tracking-tight text-ink-900 dark:text-white text-lg whitespace-nowrap">
          <span class="text-accent-600">Part IA</span> Revision
        </a>
        <div class="hidden md:flex items-center gap-1 ml-4 text-sm">
          {PAPER_ORDER.map((p) => {
            const meta = PAPERS[p];
            const isActive = currentPaper === p;
            return (
              <a
                href={`/papers/${p}`}
                class={`px-3 py-1.5 rounded-md transition ${isActive ? 'bg-accent-600 text-white' : 'text-ink-700 dark:text-ink-200 hover:bg-ink-200/60 dark:hover:bg-ink-800'}`}
              >
                {meta.number}
              </a>
            );
          })}
        </div>
        <div class="flex-1"></div>
        <a href="/practice" class="hidden md:inline px-3 py-1.5 rounded-md text-sm text-ink-700 dark:text-ink-200 hover:bg-ink-200/60 dark:hover:bg-ink-800">Practice</a>
        <a href="/coding" class="hidden md:inline px-3 py-1.5 rounded-md text-sm text-ink-700 dark:text-ink-200 hover:bg-ink-200/60 dark:hover:bg-ink-800">Coding</a>
        <a href="/flashcards" class="hidden md:inline px-3 py-1.5 rounded-md text-sm text-ink-700 dark:text-ink-200 hover:bg-ink-200/60 dark:hover:bg-ink-800">Flashcards</a>
        <a href="/cheatsheets" class="hidden md:inline px-3 py-1.5 rounded-md text-sm text-ink-700 dark:text-ink-200 hover:bg-ink-200/60 dark:hover:bg-ink-800">Cheat sheets</a>
        <a href="/past-papers" class="hidden md:inline px-3 py-1.5 rounded-md text-sm text-ink-700 dark:text-ink-200 hover:bg-ink-200/60 dark:hover:bg-ink-800">Past papers</a>
        <a href="/progress" class="hidden md:inline px-3 py-1.5 rounded-md text-sm text-ink-700 dark:text-ink-200 hover:bg-ink-200/60 dark:hover:bg-ink-800">Progress</a>
        <button id="theme-toggle" class="p-1.5 rounded-md text-ink-600 dark:text-ink-300 hover:bg-ink-200/60 dark:hover:bg-ink-800" aria-label="Toggle theme" title="Toggle theme">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707"/><circle cx="12" cy="12" r="4"/></svg>
        </button>
      </nav>
    </header>

    <main class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
      <slot />
    </main>

    <footer class="mt-20 py-8 border-t border-ink-200 dark:border-ink-800 text-sm text-ink-500 dark:text-ink-400 text-center">
      Built for Avaneesh's Part IA exams · June 2026 · Source notes from Obsidian vault
    </footer>

    <script>
      const t = document.getElementById('theme-toggle');
      t?.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      });
    </script>
  </body>
</html>
