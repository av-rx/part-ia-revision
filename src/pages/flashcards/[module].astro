---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import Flashcards from '../../components/Flashcards.tsx';
import { MODULES, type ModuleSlug } from '../../lib/syllabus';

export async function getStaticPaths() {
  const decks = await getCollection('flashcards');
  return decks.map((d: CollectionEntry<'flashcards'>) => ({
    params: { module: d.data.module },
    props: { deck: d.data },
  }));
}

type Props = { deck: { module: string; title: string; cards: any[] } };
const { deck } = Astro.props as Props;
const module = deck.module as ModuleSlug;
const meta = MODULES[module];
---
<BaseLayout title={`${meta?.title ?? deck.title} flashcards`} currentModule={module} currentPaper={meta?.paper}>
  <nav class="text-sm text-ink-500 dark:text-ink-400 mb-2">
    <a href="/flashcards" class="hover:underline">Flashcards</a>
    <span class="mx-2">/</span>
    <a href={`/modules/${module}`} class="hover:underline">{meta?.title ?? deck.title}</a>
  </nav>

  <Flashcards client:load module={deck.module} title={deck.title} cards={deck.cards} />
</BaseLayout>
