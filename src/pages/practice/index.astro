---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { MODULES, MODULE_ORDER, type ModuleSlug } from '../../lib/syllabus';

const all = await getCollection('practice-questions');
const present = new Map<string, number>(all.map((e) => [e.data.module, e.data.questions.length] as [string, number]));

---
<BaseLayout title="Practice Questions">
  <header class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight">Practice Questions</h1>
    <p class="text-ink-500 dark:text-ink-400 mt-2 max-w-2xl">
      Structured exam practice with detailed step-by-step markschemes. Questions progress from simple recall up to full Tripos-style problems.
    </p>
  </header>

  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-3">
    {MODULE_ORDER.map((slug) => {
      const m = MODULES[slug as ModuleSlug];
      const count = present.get(slug);
      return count !== undefined && count > 0 ? (
        <a href={`/practice/${slug}`} class="rounded-lg border border-ink-200 dark:border-ink-800 bg-white dark:bg-ink-900 p-4 hover:border-accent-500 transition">
          <h3 class="font-semibold text-ink-900 dark:text-white">{m.title}</h3>
          <p class="text-sm text-ink-500 dark:text-ink-400 mt-1">{m.short} · {count} question{count !== 1 ? 's' : ''}</p>
        </a>
      ) : (
        <div class="rounded-lg border border-dashed border-ink-200 dark:border-ink-800 bg-ink-50/50 dark:bg-ink-950/30 p-4 opacity-70">
          <h3 class="font-semibold text-ink-700 dark:text-ink-300">{m.title}</h3>
          <p class="text-sm text-ink-400 mt-1">Coming soon</p>
        </div>
      );
    })}
  </div>
</BaseLayout>
