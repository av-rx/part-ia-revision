---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProgressMap from '../components/ProgressMap.tsx';
import { getCollection } from 'astro:content';

const practiceEntries = await getCollection('practice-questions');
const practiceModules: Record<string, string[]> = {};
for (const entry of practiceEntries) {
  if (entry.data.questions.length > 0) {
    practiceModules[entry.data.module] = entry.data.questions.map((q: { id: string }) => q.id);
  }
}
---
<BaseLayout title="Progress">
  <header class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight">Progress</h1>
    <p class="text-ink-500 dark:text-ink-400 mt-2 max-w-2xl">
      Heat-map of your confidence across every topic in every module. Set confidence on a topic page; this view aggregates and shows where to focus.
    </p>
  </header>

  <ProgressMap client:load practiceModules={practiceModules} />
</BaseLayout>
