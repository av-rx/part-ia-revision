---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProgressMap from '../components/ProgressMap.tsx';
---
<BaseLayout title="Progress">
  <header class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight">Progress</h1>
    <p class="text-ink-500 dark:text-ink-400 mt-2 max-w-2xl">
      Heat-map of your confidence across every topic in every module. Set confidence on a topic page; this view aggregates and shows where to focus.
    </p>
  </header>

  <ProgressMap client:load />
</BaseLayout>
